# Signer
XMTP_WALLET_KEY=
# Database
XMTP_DB_DIRECTORY=.database
XMTP_DB_ENCRYPTION_KEY=
# Deployment
XMTP_ENV=production
# Debugging
XMTP_FORCE_DEBUG_LEVEL=Error
XMTP_FORCE_DEBUG=true
# Pinata IPFS File Upload
PINATA_GATEWAY=
PINATA_JWT=
# "isFromOwner" middleware
XMTP_OWNER_ADDRESS=
# Gateway (only needed for "npm run start:gateway")
PAYER_PRIVATE_KEY=
REDIS_URL=redis://localhost:6379
APP_CHAIN_RPC_URL=
APP_CHAIN_WSS_URL=
SETTLEMENT_CHAIN_RPC_URL=
SETTLEMENT_CHAIN_WSS_URL=
CONTRACTS_ENVIRONMENT=testnet
LOG_LEVEL=info
